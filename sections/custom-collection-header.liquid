{{ 'custom-homepage.css' | asset_url | stylesheet_tag }}

<div class="custom-collection-header reveal-on-scroll">
  {% if section.settings.label != blank %}
    <div class="custom-collection-header__label">{{ section.settings.label }}</div>
  {% endif %}
  {% if section.settings.heading != blank %}
    <h2 class="custom-collection-header__title">{{ section.settings.heading }}</h2>
  {% endif %}
  {% if section.settings.subtitle != blank %}
    <p class="custom-collection-header__subtitle">{{ section.settings.subtitle }}</p>
  {% endif %}
</div>

{% schema %}
{
  "name": "Заголовок коллекции",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Подпись",
      "default": "КАТАЛОГ"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Заголовок",
      "default": "Наши авторамки"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Подзаголовок",
      "default": "Выберите идеальную рамку для вашего автомобиля"
    }
  ],
  "presets": [
    {
      "name": "Заголовок коллекции"
    }
  ]
}
{% endschema %}
