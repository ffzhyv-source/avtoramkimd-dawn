{{ 'custom-homepage.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .custom-hero {
    min-height: {{ section.settings.min_height }}px;
  }
{%- endstyle -%}

<section class="custom-hero" id="hero-{{ section.id }}">
  <div class="custom-hero__overlay"></div>
  
  {% if section.settings.image != blank %}
    <div class="custom-hero__bg">
      {{ section.settings.image | image_url: width: 1920 | image_tag:
        loading: 'eager',
        widths: '375, 750, 1100, 1500, 1920',
        sizes: '100vw'
      }}
    </div>
  {% else %}
    <div class="custom-hero__bg" style="background: #1b1b1b;"></div>
  {% endif %}

  <div class="custom-hero__content">
    {% if section.settings.badge_text != blank %}
      <div class="custom-hero__badge">{{ section.settings.badge_text }}</div>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h1 class="custom-hero__title">
        {{ section.settings.heading }}
        {% if section.settings.heading_highlight != blank %}
          <span>{{ section.settings.heading_highlight }}</span>
        {% endif %}
      </h1>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="custom-hero__subtitle">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="custom-hero__buttons">
      {% if section.settings.button_label_1 != blank %}
        <a href="{{ section.settings.button_link_1 }}" class="custom-hero__btn custom-hero__btn--primary">
          {{ section.settings.button_label_1 }}
        </a>
      {% endif %}
      {% if section.settings.button_label_2 != blank %}
        <a href="{{ section.settings.button_link_2 }}" class="custom-hero__btn custom-hero__btn--secondary">
          {{ section.settings.button_label_2 }}
        </a>
      {% endif %}
    </div>
  </div>

  <div class="custom-hero__scroll-hint">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 5v14M19 12l-7 7-7-7"/>
    </svg>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Фоновое изображение"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Бейдж текст",
      "default": "АВТОРАМКИ №1 В МОЛДОВЕ"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Заголовок",
      "default": "Премиальные авторамки"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Выделенный текст (золотой)",
      "default": "для вашего автомобиля"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Подзаголовок",
      "default": "Широкий выбор рамок для номерных знаков с доставкой по всей Молдове. Качество, стиль и надёжность."
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Кнопка 1",
      "default": "Смотреть каталог"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Ссылка кнопки 1"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Кнопка 2",
      "default": "О нас"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Ссылка кнопки 2"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 350,
      "max": 700,
      "step": 10,
      "default": 520,
      "unit": "px",
      "label": "Минимальная высота"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
