{{ 'custom-homepage.css' | asset_url | stylesheet_tag }}

<section class="custom-promo" id="promo-{{ section.id }}">
  <div class="custom-promo__container">
    <div class="custom-promo__content">
      {% if section.settings.tag != blank %}
        <div class="custom-promo__tag">{{ section.settings.tag }}</div>
      {% endif %}
      
      {% if section.settings.heading != blank %}
        <h2 class="custom-promo__title">{{ section.settings.heading }}</h2>
      {% endif %}
      
      {% if section.settings.text != blank %}
        <p class="custom-promo__text">{{ section.settings.text }}</p>
      {% endif %}

      <div class="custom-promo__stats">
        {% for block in section.blocks %}
          {% if block.type == 'stat' %}
            <div class="custom-promo__stat" {{ block.shopify_attributes }}>
              <span class="custom-promo__stat-number">{{ block.settings.number }}</span>
              <span class="custom-promo__stat-label">{{ block.settings.label }}</span>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if section.settings.button_label != blank %}
        <div style="margin-top: 2rem;">
          <a href="{{ section.settings.button_link }}" class="custom-hero__btn custom-hero__btn--primary">
            {{ section.settings.button_label }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      {% endif %}
    </div>

    <div class="custom-promo__visual">
      <div class="custom-promo__visual-box">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 900 | image_tag:
            loading: 'lazy',
            widths: '375, 550, 750, 900',
            sizes: '(max-width: 768px) 100vw, 450px'
          }}
        {% else %}
          <div style="padding: 4rem; text-align: center; color: rgba(255,255,255,0.3); font-size: 1.2rem;">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            <p style="margin-top: 1rem;">Добавьте изображение</p>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Промо баннер",
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Тег",
      "default": "СПЕЦИАЛЬНОЕ ПРЕДЛОЖЕНИЕ"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Заголовок",
      "default": "Стильные рамки для каждого авто"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Текст",
      "default": "Большой выбор авторамок из прочных материалов. Придайте вашему автомобилю индивидуальный стиль с нашими премиальными рамками."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Изображение"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Текст кнопки",
      "default": "Смотреть все"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Ссылка кнопки"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Статистика",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Число",
          "default": "500+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Подпись",
          "default": "Клиентов"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Промо баннер",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "number": "500+",
            "label": "Довольных клиентов"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "50+",
            "label": "Моделей рамок"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "5★",
            "label": "Рейтинг"
          }
        }
      ]
    }
  ]
}
{% endschema %}
