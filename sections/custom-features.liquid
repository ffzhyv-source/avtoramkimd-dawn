{{ 'custom-homepage.css' | asset_url | stylesheet_tag }}

<section class="custom-features" id="features-{{ section.id }}">
  <div class="custom-features__container">
    <div class="custom-features__header reveal-on-scroll">
      {% if section.settings.label != blank %}
        <div class="custom-features__label">{{ section.settings.label }}</div>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="custom-features__title">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="custom-features__grid">
      {% for block in section.blocks %}
        <div class="custom-features__card reveal-on-scroll reveal-delay-{{ forloop.index }}" {{ block.shopify_attributes }}>
          <div class="custom-features__icon">
            {% case block.settings.icon %}
              {% when 'shield' %}
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L3 7v5c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5zm0 2.18l7 3.82v4c0 4.52-3.13 8.69-7 9.93C8.13 20.69 5 16.52 5 12V8l7-3.82z"/><path d="M10 15.5l-3.5-3.5 1.41-1.41L10 12.67l5.59-5.59L17 8.5l-7 7z"/></svg>
              {% when 'truck' %}
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9l1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg>
              {% when 'star' %}
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {% when 'refresh' %}
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.65 6.35A7.958 7.958 0 0012 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0112 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>
              {% when 'heart' %}
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
              {% when 'award' %}
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
              {% else %}
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {% endcase %}
          </div>
          <h3 class="custom-features__card-title">{{ block.settings.title }}</h3>
          <p class="custom-features__card-text">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const reveals = document.querySelectorAll('.reveal-on-scroll');
    if (!reveals.length) return;
    
    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    
    reveals.forEach(function(el) { observer.observe(el); });
  });
</script>

{% schema %}
{
  "name": "Преимущества",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Подпись",
      "default": "ПОЧЕМУ МЫ"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Заголовок",
      "default": "Наши преимущества"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Преимущество",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Иконка",
          "options": [
            { "value": "shield", "label": "Щит (гарантия)" },
            { "value": "truck", "label": "Грузовик (доставка)" },
            { "value": "star", "label": "Звезда (качество)" },
            { "value": "refresh", "label": "Обновление (возврат)" },
            { "value": "heart", "label": "Сердце" },
            { "value": "award", "label": "Награда" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Заголовок",
          "default": "Гарантия качества"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Описание",
          "default": "Все наши рамки проходят строгий контроль качества"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Преимущества",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "shield",
            "title": "Гарантия качества",
            "text": "Все рамки проходят строгий контроль качества и имеют гарантию"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "truck",
            "title": "Быстрая доставка",
            "text": "Доставка по всей Молдове за 1-3 рабочих дня"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "star",
            "title": "Премиум материалы",
            "text": "Используем только прочные материалы для долговечности"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "refresh",
            "title": "Простой возврат",
            "text": "14 дней на возврат, если товар не подошёл"
          }
        }
      ]
    }
  ]
}
{% endschema %}
